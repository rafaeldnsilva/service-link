# ============================================
# ServiceLink — Template de Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores.
# O arquivo .env real NÃO deve ser commitado no git.

# --------------------------------------------
# Banco de Dados PostgreSQL
# --------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=SUA_SENHA_AQUI
DATABASE_URL=postgresql://postgres:SUA_SENHA_AQUI@localhost:5432/postgres

# --------------------------------------------
# Supabase (app mobile)
# Obtenha em: https://supabase.com → Project Settings → API
# --------------------------------------------
EXPO_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=SUA_ANON_KEY_AQUI
